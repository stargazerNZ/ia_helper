{
    "app-id": "io.github.stargazernz.IAHelper",
    "runtime": "org.gnome.Platform",
    "runtime-version": "48",
    "sdk": "org.gnome.Sdk",
    "command": "ia-helper",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=xdg-download"
    ],
    "modules": [
        "python3-internetarchive.json",
        {
            "name": "ia-helper",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --prefix=${FLATPAK_DEST} --no-deps --no-build-isolation .",
                "install -Dm644 data/io.github.stargazernz.IAHelper.desktop ${FLATPAK_DEST}/share/applications/io.github.stargazernz.IAHelper.desktop",
                "install -Dm644 data/io.github.stargazernz.IAHelper.metainfo.xml ${FLATPAK_DEST}/share/metainfo/io.github.stargazernz.IAHelper.metainfo.xml",
                "install -Dm644 data/icons/hicolor/scalable/apps/io.github.stargazernz.IAHelper.svg ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps/io.github.stargazernz.IAHelper.svg"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/stargazerNZ/ia_helper.git",
                    "tag": "v1.0.0"
                }
            ]
        }
    ]
}
